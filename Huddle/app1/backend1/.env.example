# DJANGO CONFIG
SECRET_KEY=django-insecure-auth-services-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,auth-service

# CORS SETTINGS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# DATABASE CONFIG (defaults to SQLite if not provided)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=auth_db
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=postgres-db
# DB_PORT=5432

# EMAIL SETTINGS (For Password Reset)
EMAIL_HOST_USER=yourgmail@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

DATABASE_URL=postgresql://postgres:db2312@localhost:5432/backend